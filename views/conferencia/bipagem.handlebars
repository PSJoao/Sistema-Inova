{{!< main}} {{#section "head" }} <link href="/public/styles/bipagemExpedicao.css" rel="stylesheet">
    {{/section}}

    <div class="bipagem-wrapper">

        <div class="bipagem-header">
            <h1 class="d-none d-md-block">{{title}}</h1>
        </div>

        <div class="bipagem-grid">

            {{!-- PAINEL 1: NOTA ATIVA (Foco Principal) e ESTADO VAZIO --}}
            <div class="bipagem-panel"
                style="position: relative; display: flex; flex-direction: column; min-height: 400px; padding: 0;">

                {{!-- ESTADO VAZIO (Quando nenhuma nota está ativa) --}}
                <div id="empty-state-panel"
                    style="text-align: center; padding: 4rem 2rem; flex-grow: 1; display: flex; flex-direction: column; justify-content: center; align-items: center;">
                    <div
                        style="background: rgba(255, 107, 0, 0.1); width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                        <i class="fas fa-barcode fa-3x" style="color: var(--accent-orange);"></i>
                    </div>
                    <h3 style="color: white; font-weight: 600; margin-bottom: 10px;">Aguardando Bipagem</h3>
                    <p style="color: var(--text-muted); font-size: 1rem; max-width: 300px; line-height: 1.5;">Bipe o
                        código de barras de uma Nota Fiscal para iniciar a conferência, ou selecione uma nota pendente
                        na lista de pendentes.</p>
                </div>

                <div id="active-note-panel" style="display: none; height: 100%; flex-direction: column;">
                    <div class="bipagem-panel-title"
                        style="display: flex; justify-content: space-between; align-items: center; background: rgba(255, 107, 0, 0.05); padding: 15px 20px; border-bottom: 1px solid rgba(255, 107, 0, 0.1); border-radius: 12px 12px 0 0;">
                        <div style="display: flex; flex-direction: row; gap: 10px;">
                            <span class="nota-ativa-titulo"
                                style="font-size: 1.3rem; font-weight: bold; color: var(--accent-orange); display: flex; align-items: center; gap: 8px;">
                                <i class="fas fa-file-invoice"></i> NF <span id="active-nfe-number">---</span>
                            </span>
                            <button class="btn-bip danger" id="btn-close-active-note" title="Pausar / Limpar Nota"
                                style="padding: 0.4rem 0.8rem; font-size: 0.85rem; border-radius: 6px;">
                                <i class="fas fa-pause" id="btn-close-icon"></i> <span id="btn-close-text">Pausar</span>
                            </button>
                            <button class="btn-bip success" id="btn-finalize-active-note" title="Finalizar Nota"
                                style="padding: 0.4rem 0.8rem; font-size: 0.85rem; border-radius: 6px; display: none;">
                                <i class="fas fa-check" id="btn-finalize-icon"></i> <span
                                    id="btn-finalize-text">Finalizar</span>
                            </button>
                            {{!--<span id="active-nfe-cliente"
                                style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 4px;"></span>--}}
                        </div>
                    </div>

                    <div style="padding: 20px; flex-grow: 1; display: flex; flex-direction: column;">
                        <div class="progress-container"
                            style="margin-bottom: 20px; background: rgba(0,0,0,0.3); border-radius: 20px; height: 24px; position: relative; overflow: hidden; border: 1px solid rgba(255,255,255,0.05);">
                            <div id="active-progress-bar" class="progress-bar"
                                style="background: linear-gradient(90deg, var(--accent-orange), #ff8c00); height: 100%; transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1); width: 0%;">
                            </div>
                            <div id="active-progress-text"
                                style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.85rem; color: white; text-shadow: 1px 1px 2px rgba(0,0,0,0.8); pointer-events: none;">
                                0/0 (0%)</div>
                        </div>

                        <div class="bip-status-box"
                            style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                            <h6
                                style="color: var(--text-secondary); margin-top: 0; margin-bottom: 10px; font-size: 0.9rem;">
                                Carregadores</h6>
                            <ul id="lista-carregadores-bipados" class="carregadores-list"
                                style="list-style: none; padding: 0; margin: 0 0 10px 0; max-height: 100px; overflow-y: auto;">
                                <li style="background: transparent; padding: 0;"><span class="text-muted"
                                        style="font-size: 0.9rem;">Nenhum bipado.</span></li>
                            </ul>
                        </div>

                        <div
                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; border-bottom: 1px dashed rgba(255,255,255,0.1); padding-bottom: 10px;">
                            <span style="color: var(--text-secondary); font-size: 0.95rem; font-weight: 600;">
                                <i class="fas fa-box-open" style="margin-right: 5px;"></i> Itens da Nota
                            </span>
                            {{!--<span id="active-nfe-conta" class="badge"
                                style="background: rgba(255,255,255,0.1); color: var(--text-muted); font-size: 0.75rem;"></span>--}}
                        </div>

                        <div id="active-volumes-list" class="active-volumes-list"
                            style="overflow-y: auto; flex-grow: 1; max-height: 500px; padding-right: 5px;">
                            {{!-- Renderizado via JS --}}
                        </div>
                    </div>
                </div>
            </div>

            {{!-- PAINEL 2: LISTAS (Pendentes / Em Pausa e Conferidas) --}}
            <div style="display: flex; flex-direction: column; gap: 20px;">
                <div class="bipagem-panel">
                    <div class="bipagem-panel-title">
                        Pendentes / Em Pausa
                    </div>
                    <div id="pending-notes-list" style="min-height: 100px;">
                        {{!-- Renderizado via JS --}}
                        <div class="text-center mt-4" style="font-size: 0.9rem; color: var(--text-muted);">
                            <i class="fas fa-check-double fa-2x mb-2"></i><br>
                            Lista vazia.
                        </div>
                    </div>
                </div>

                <div class="bipagem-panel">
                    <div class="bipagem-panel-title"
                        style="display: flex; justify-content: space-between; align-items: center;">
                        <span>Conferidas</span>
                        <button id="btn-clear-completed" class="btn-bip danger" title="Limpar histórico da tela"
                            style="padding: 0.2rem 0.6rem; display: none;">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>
                    <div id="completed-notes-list" style="min-height: 150px; overflow-y: auto; max-height: 400px;">
                        {{!-- Renderizado via JS --}}
                        <div class="text-center mt-3" style="font-size: 0.9rem; color: var(--text-muted);">
                            Nenhuma nota aguardando conferência.
                        </div>
                    </div>
                </div>
            </div>

            <style>
                /* Estilos apenas para garantir a responsividade sem quebrar o HTML existente */
                .bip-status-grid {
                    display: flex;
                    justify-content: center;
                    /* Centraliza a caixa inteira em telas grandes/pequenas */
                    width: 100%;
                }

                .bip-status-box {
                    width: 100%;
                    max-width: 1200px;
                    /* Impede que fique absurdamente esticado em telas ultrawide */
                }

                @media (max-width: 480px) {
                    .bip-responsive-item {
                        flex-basis: 100% !important;
                        /* Força os itens a caírem um sobre o outro no mobile */
                    }

                    .bip-status-box h6 {
                        text-align: center !important;
                        /* Centraliza o título no mobile */
                    }
                }
            </style>

            <div class="bip-status-grid" style="margin-bottom: 15px;">
                <div class="bip-status-box"
                    style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); padding: 10px 15px; border-radius: 8px;">
                    <h6 style="color: var(--text-secondary); margin-top: 0; margin-bottom: 10px; font-size: 0.85rem;">
                        Configurações Globais</h6>

                    <!-- Adicionado apenas justify-content: center no style abaixo -->
                    <div
                        style="display: flex; flex-wrap: wrap; gap: 10px; align-items: center; justify-content: center;">

                        <!-- Adicionada apenas a classe bip-responsive-item -->
                        <div id="ml-mode-container" class="bip-responsive-item"
                            style="flex: 1; min-width: 200px; display: flex; align-items: center; justify-content: space-between; background: rgba(0,0,0,0.2); padding: 8px 12px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s;">
                            <span id="ml-mode-text"
                                style="color: var(--text-muted); font-size: 0.85rem; font-weight: bold; transition: color 0.3s;">Modo
                                Mercado Livre</span>
                            <label class="switch"
                                style="position: relative; display: inline-block; width: 34px; height: 18px; margin: 0;">
                                <input type="checkbox" id="toggle-modo-ml" style="opacity: 0; width: 0; height: 0;">
                                <span class="slider round"
                                    style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #ccc; transition: .4s; border-radius: 34px;"></span>
                            </label>
                        </div>

                        <!-- Adicionada apenas a classe bip-responsive-item -->
                        <label class="bip-responsive-item"
                            style="flex: 1; min-width: 200px; cursor: pointer; display: flex; align-items: center; justify-content: space-between; margin-bottom: 0; background: rgba(0,0,0,0.2); padding: 8px 12px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.05);">
                            <span id="label-modo-carregador"
                                style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); transition: color 0.3s;">Com
                                Carregador</span>
                            <div style="position: relative; display: inline-block; width: 40px; height: 20px;">
                                <input type="checkbox" id="chk-sem-carregador" style="opacity: 0; width: 0; height: 0;"
                                    onchange="
                                    const lbl = document.getElementById('label-modo-carregador');
                                    if(this.checked) {
                                        lbl.innerText = 'Sem Carregador';
                                        lbl.style.color = 'var(--accent-orange)';
                                        this.nextElementSibling.style.backgroundColor = 'var(--accent-orange)';
                                        this.nextElementSibling.style.borderColor = 'var(--accent-orange)';
                                        this.nextElementSibling.nextElementSibling.style.transform = 'translateX(20px)';
                                        this.nextElementSibling.nextElementSibling.style.backgroundColor = '#1e1e2f';
                                    } else {
                                        lbl.innerText = 'Com Carregador';
                                        lbl.style.color = 'var(--text-secondary)';
                                        this.nextElementSibling.style.backgroundColor = 'rgba(255,255,255,0.05)';
                                        this.nextElementSibling.style.borderColor = 'rgba(255,255,255,0.1)';
                                        this.nextElementSibling.nextElementSibling.style.transform = 'translateX(0)';
                                        this.nextElementSibling.nextElementSibling.style.backgroundColor = '#888';
                                    }
                                ">
                                <span
                                    style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(255,255,255,0.05); transition: 0.3s; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1);"></span>
                                <span
                                    style="position: absolute; height: 12px; width: 12px; left: 4px; bottom: 4px; background-color: #888; transition: 0.3s; border-radius: 50%; pointer-events: none;"></span>
                            </div>
                        </label>
                    </div>
                </div>
            </div>
        </div>



    </div>

    {{!-- BOTÕES FLUTUANTES: CONTROLE DE PALETES --}}
    <div id="fab-paletes-container"
        style="position: fixed; bottom: 100px; right: 20px; z-index: 998; display: flex; flex-direction: column; align-items: center; gap: 10px;">
        {{!-- Botão menor: Novo Palete (+) --}}
        <button id="fab-novo-palete" title="Criar novo palete"
            style="width: 40px; height: 40px; border-radius: 50%; border: none; background: linear-gradient(135deg, #ff8c00, #ff6b00); color: white; font-size: 1.2rem; font-weight: bold; cursor: pointer; box-shadow: 0 4px 15px rgba(255, 107, 0, 0.4); display: flex; align-items: center; justify-content: center; transition: transform 0.2s, box-shadow 0.2s;">
            <i class="fas fa-plus"></i>
        </button>
        {{!-- Botão maior: Palete Atual --}}
        <div style="position: relative;">
            <button id="fab-palete-atual" title="Ver paletes"
                style="width: 56px; height: 56px; border-radius: 50%; border: none; background: linear-gradient(135deg, #ff8c00, #e65100); color: white; font-size: 1.1rem; font-weight: 900; cursor: pointer; box-shadow: 0 4px 20px rgba(255, 107, 0, 0.5); display: flex; align-items: center; justify-content: center; transition: transform 0.2s, box-shadow 0.2s; letter-spacing: -0.5px;">
                P1
            </button>
            <span id="fab-palete-count"
                style="position: absolute; top: -6px; right: -6px; background: #28a745; color: white; font-size: 0.7rem; font-weight: bold; min-width: 20px; height: 20px; border-radius: 10px; display: flex; align-items: center; justify-content: center; padding: 0 4px; box-shadow: 0 2px 6px rgba(0,0,0,0.4);">
                0
            </span>
        </div>
    </div>

    {{!-- FOOTER: INPUT FIXO DE BIPAGEM --}}
    <div class="input-area-fixed"
        style="position: fixed; bottom: 0; left: 0; width: 100%; backdrop-filter: blur(10px); padding: 15px; border-top: 1px solid rgba(255,255,255,0.05); z-index: 999; display: flex; justify-content: center;">
        <div class="input-icon-wrapper" style="position: relative; width: 100%; max-width: 600px;">
            <i class="fas fa-barcode"
                style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--accent-orange); font-size: 1.2rem;"></i>
            <input type="text" class="input-bipagem" id="conferenciaInput"
                placeholder="Bipe a Chave da NF, SKU ou Código..." autocomplete="off" autofocus
                style="width: 100%; padding: 12px 15px 12px 45px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: transparent; color: white; font-size: 1.1rem; outline: none; transition: all 0.3s;">
        </div>
    </div>

    <audio id="audio-success" src="/public/sounds/notification.mp3"></audio>
    <audio id="audio-error" src="/public/sounds/error.mp3"></audio>

    {{#section "scripts"}}
    <script src="/public/scripts/toastSystem.js"></script>
    <script src="/public/scripts/conferenciaManager.js"></script>
    <style>
        /* Estilo do toggle switch */
        .switch {
            position: relative;
            display: inline-block;
            width: 40px;
            height: 20px;
        }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #555;
            -webkit-transition: .4s;
            transition: .4s;
            border-radius: 34px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 14px;
            width: 14px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            -webkit-transition: .4s;
            transition: .4s;
            border-radius: 50%;
        }

        input:checked+.slider {
            background-color: var(--accent-orange);
        }

        input:focus+.slider {
            box-shadow: 0 0 1px var(--accent-orange);
        }

        input:checked+.slider:before {
            -webkit-transform: translateX(20px);
            -ms-transform: translateX(20px);
            transform: translateX(20px);
        }

        .carregador-badge {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 8px 12px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.2s;
            color: var(--text-secondary);
        }

        .carregador-badge.selected {
            background: var(--accent-orange);
            border-color: var(--accent-orange);
            color: white;
        }

        /* Ajustes extras para garantir o comportamento escuro dentro do wrapper sem afetar o layout raiz */
        body {
            padding-bottom: 80px;
        }

        .nota-pendente-item,
        .nota-conferida-item {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 12px;
            margin-bottom: 8px;
            border-radius: 6px;
            display: flex;
            justify-content: space-between;
        }

        .volume-item {
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid #333;
            padding: 10px;
            margin-bottom: 5px;
            border-radius: 5px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .volume-item.conferido {
            border-left: 4px solid #28a745;
            background: rgba(40, 167, 69, 0.1);
        }

        .volume-item .status-icon {
            font-size: 1.5rem;
            color: #555;
        }

        .volume-item.conferido .status-icon {
            color: #28a745;
        }

        .badge-progresso {
            background: var(--accent-orange);
            color: white;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 0.8rem;
            font-weight: bold;
        }

        .input-bipagem:focus {
            border-color: var(--accent-orange) !important;
            box-shadow: 0 0 0 2px rgba(255, 107, 0, 0.2);
        }

        /* --- RESPONSIVIDADE ESTRITA PARA CELULARES --- */
        @media (max-width: 768px) {
            .bipagem-grid {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            .bipagem-panel {
                padding: 10px;
                min-height: auto !important;
            }

            #empty-state-panel {
                padding: 2rem 1rem !important;
            }

            /* Esconde painel vazio em telas pequenas para não atrapalhar */
            #empty-state-panel:not(.force-show) {
                display: none !important;
                min-height: 0 !important;
            }

            .bipagem-panel {
                min-height: auto !important;
            }

            .nota-ativa-titulo {
                font-size: 1.1rem !important;
            }

            .volume-item {
                padding: 6px;
                gap: 8px;
                flex-direction: column;
                align-items: flex-start;
            }

            .volume-item .status-icon {
                font-size: 1.2rem;
                align-self: center;
                margin-bottom: -5px;
            }

            .volume-item .volume-details {
                font-size: 0.85rem;
                line-height: 1.2;
            }

            .bipagem-panel-title {
                padding: 10px !important;
                flex-direction: column;
                gap: 5px;
                align-items: flex-start !important;
            }

            #btn-close-active-note {
                align-self: flex-end;
            }

            .btn-bip {
                padding: 0.2rem 0.5rem !important;
                font-size: 0.8rem !important;
            }

            .badge-progresso {
                font-size: 0.7rem;
            }
        }

        /* Item sem EAN - efeito hover clicável */
        .volume-item[data-manual-check-idx]:not(.conferido):hover {
            background: rgba(220, 53, 69, 0.1) !important;
            border-color: rgba(220, 53, 69, 0.3) !important;
            transition: all 0.2s;
        }

        .btn-copy-sku:hover {
            color: var(--accent-orange) !important;
        }

        /* Botões flutuantes de paletes */
        #fab-palete-atual:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 25px rgba(255, 107, 0, 0.6);
        }

        #fab-palete-atual:active {
            transform: scale(0.95);
        }

        #fab-novo-palete:hover {
            transform: scale(1.1);
            box-shadow: 0 4px 18px rgba(255, 107, 0, 0.5);
        }

        #fab-novo-palete:active {
            transform: scale(0.9);
        }

        @media (max-width: 768px) {
            #fab-paletes-container {
                right: 10px !important;
                bottom: 100px !important;
            }

            #fab-palete-atual {
                width: 48px !important;
                height: 48px !important;
                font-size: 0.95rem !important;
            }

            #fab-novo-palete {
                width: 34px !important;
                height: 34px !important;
                font-size: 1rem !important;
            }
        }
    </style>
    {{/section}}