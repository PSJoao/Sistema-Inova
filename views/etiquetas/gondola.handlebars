<link rel="stylesheet" href="/public/styles/etiquetas.css">

<div class="content-card">
    <div class="page-header-actions mb-4">
        <h1 class="page-title"><i class="fas fa-boxes text-muted mr-2"></i> Estoque de Transição: Gôndola</h1>
    </div>

    <div class="row">
        <div class="col-lg-5 mb-4">
            
            <div class="gondola-card mb-4">
                <div class="gondola-card-header">
                    <i class="fas fa-barcode"></i> Nova Gôndola (Bipagem)
                </div>
                <div class="gondola-card-body">
                    <form id="form-bipagem-gondola" class="mb-3">
                        <div class="form-group">
                            <label for="codigo-bipagem" class="form-label">Bipe o GTIN, GTIN Embalagem ou SKU:</label>
                            <input type="text" id="codigo-bipagem" class="form-control form-control-lg" autocomplete="off" autofocus placeholder="Aguardando leitor...">
                        </div>
                    </form>
                    <hr class="custom-hr">
                    
                    <div class="table-responsive gondola-table-wrapper" style="max-height: 350px; overflow-y: auto; border: none;">
                        <table class="table mb-0" id="tabela-bipagem-atual">
                            <thead>
                                <tr>
                                    <th style="width: 30%;">SKU</th>
                                    <th style="width: 60%;">Nome</th>
                                    <th style="width: 80px; text-align: center;">Qtd</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr id="linha-vazia"><td colspan="3" class="text-center text-muted" style="padding: 2rem 0;">Nenhum item bipado ainda.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="gondola-card-footer d-flex justify-content-between">
                    <button id="btn-limpar-gondola" class="btn btn-outline-danger"><i class="fas fa-trash-alt mr-1"></i> Limpar</button>
                    <button id="btn-salvar-gondola" class="btn btn-primary font-weight-bold"><i class="fas fa-save mr-1"></i> Finalizar Relatório</button>
                </div>
            </div>

            <br><br>
            
            <div class="col-lg-7 mb-4">
                <div class="gondola-card h-100">
                    <div class="gondola-card-header">
                        <i class="fas fa-history"></i> Histórico de Relatórios Gôndola
                    </div>
                    <div class="gondola-card-body p-0 d-flex flex-column" style="height: calc(100% - 50px);">
                        <div class="table-responsive gondola-table-wrapper" style="flex: 1; border: none;">
                            <table class="table table-hover mb-0" id="tabela-historico-gondola">
                                <thead>
                                    <tr>
                                        <th>Nome do Relatório</th>
                                        <th>Data/Hora Criação</th>
                                        <th style="width: 180px; text-align: center;">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                        </div>
                        <div class="p-2 border-top bg-light mt-auto d-flex justify-content-center">
                            <nav>
                                <ul class="pagination pagination-sm mb-0" id="paginacao-historico">
                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
            
            <br><br>

            <div class="gondola-card mt-4">
                <div class="gondola-card-header" style="border-bottom-color: #28a745;">
                    <i class="fas fa-file-excel text-success"></i> Importar Já Separados (Excel)
                </div>
                <div class="gondola-card-body">
                    <form id="form-excel-separados">
                        <div class="form-group mb-3">
                            <label for="excel-separados-file" class="form-label">Selecione a planilha (.xlsx):</label>
                            <div class="custom-file-upload mt-2">
                                <input type="file" id="excel-separados-file" accept=".xlsx, .xls" style="display: none;">
                                <label for="excel-separados-file" class="btn btn-outline-secondary w-100 mb-0" style="cursor: pointer; padding: 10px;">
                                    <i class="fas fa-upload mr-2"></i> Escolher Arquivo
                                </label>
                            </div>
                            <small id="nome-arquivo-excel" class="form-text text-center font-weight-bold mt-3" style="color: var(--accent-orange);"></small>
                        </div>
                        <button type="submit" class="btn btn-success w-100 font-weight-bold" id="btn-enviar-excel">
                            <i class="fas fa-cloud-upload-alt mr-2"></i> Subir Planilha
                        </button>
                    </form>
                    
                    <br>
                    <div id="area-pin-excel" class="mt-4 text-center p-3 rounded" style="background-color: rgba(40, 167, 69, 0.05); border: 1px solid rgba(40, 167, 69, 0.2);">
                        <p class="mb-2" style="color: var(--text-secondary); font-size: 0.9em;">A senha (PIN) de hoje para usar esta planilha é:</p>
                        <h2 class="text-success font-weight-bold display-4 mb-0" id="pin-display" style="letter-spacing: 10px;">{{senhaDoDia}}</h2>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="/public/scripts/gondolaManager.js"></script>