{{#section "head" }}
<link href="/public/styles/dashboardExpedicao.css" rel="stylesheet">
{{/section}}

<div class="dashboard-wrapper">
    <div class="dashboard-header mb-4">
        <h1 class="page-title-dark"><i class="fas fa-boxes text-muted mr-2"></i> Estoque de Transição: Gôndola</h1>
    </div>

    <div class="row">
        <div class="col-lg-5 mb-4">
            
            <div class="dashboard-panel mb-4">
                <div class="panel-title d-flex align-items-center" style="border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 15px; padding-bottom: 10px;">
                    <i class="fas fa-barcode mr-2"></i> <span id="titulo-painel-bipagem">Nova Gôndola (Bipagem)</span>
                    <span id="badge-editando" class="badge badge-warning ml-auto" style="display: none; color: #212529;"><i class="fas fa-edit"></i> <span id="nome-relatorio-editando">Editando</span></span>
                </div>
                <div>
                    <form id="form-bipagem-gondola" class="mb-3">
                        <div class="form-group">
                            <label for="codigo-bipagem" style="color: var(--text-secondary); margin-bottom: 8px;">Bipe o GTIN, GTIN Embalagem ou SKU:</label>
                            <input type="text" id="codigo-bipagem" class="form-control-dark" autocomplete="off" autofocus placeholder="Aguardando leitor...">
                        </div>
                    </form>
                    <hr class="custom-hr">
                    <div style="max-height: 350px; overflow-y: auto; margin-top: 12px;">
                        <table class="table dataTable mb-0" id="tabela-bipagem-atual" style="table-layout: fixed; width: 100%;">
                            <colgroup>
                                <col style="width: 28%;">
                                <col style="width: 54%;">
                                <col style="width: 18%;">
                            </colgroup>
                            <thead>
                                <tr>
                                    <th style="font-size: 0.8rem;">SKU</th>
                                    <th style="font-size: 0.8rem;">Nome</th>
                                    <th style="font-size: 0.8rem; text-align: center;">Qtd</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr id="linha-vazia"><td colspan="3" class="text-center text-muted" style="padding: 2rem 0;">Nenhum item bipado ainda.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="mt-4 pt-3" style="border-top: 1px solid rgba(255,255,255,0.05); display: flex; flex-wrap: wrap; gap: 10px; justify-content: space-between; align-items: center;">
                    <div style="display: flex; gap: 10px;">
                        <button id="btn-limpar-gondola" class="btn-premium outline btn-sm" style="border-color: #dc3545; color: #dc3545;"><i class="fas fa-trash-alt"></i> Limpar</button>
                        <button id="btn-cancelar-edicao" class="btn-premium outline btn-sm" style="display: none;"><i class="fas fa-times"></i> Cancelar</button>
                    </div>
                    <button id="btn-salvar-gondola" class="btn-premium orange btn-sm"><i class="fas fa-save"></i> <span>Finalizar</span></button>
                </div>
            </div>

            <br><br>
            
            <div class="col-lg-7 mb-4">
                <div class="dashboard-panel h-100 d-flex flex-column">
                    <h4 class="panel-title"><i class="fas fa-history"></i> Histórico de Relatórios Gôndola</h4>
                    
                    <div class="d-flex flex-column" style="flex: 1;">
                        <div style="flex: 1; overflow-x: hidden;">
                            <table class="table dataTable mb-0" id="tabela-historico-gondola" style="table-layout: fixed; width: 100%;">
                                <colgroup>
                                    <col style="width: 50%;">
                                    <col style="width: 30%;">
                                    <col style="width: 20%;">
                                </colgroup>
                                <thead>
                                    <tr>
                                        <th style="font-size: 0.8rem;">Relatório</th>
                                        <th style="font-size: 0.8rem;">Data/Hora</th>
                                        <th style="font-size: 0.8rem; text-align: center;">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                        </div>
                        <div class="p-3 mt-auto d-flex justify-content-center" style="background-color: #242426; border-top: 1px solid rgba(255,255,255,0.05);">
                            <div id="paginacao-historico" style="display: flex; justify-content: center; gap: 10px;">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <br><br>

            <div class="dashboard-panel mt-4">
                <h4 class="panel-title" style="color: #28a745;"><i class="fas fa-file-excel"></i> Importar Já Separados (Excel)</h4>
                
                <div>
                    <form id="form-excel-separados">
                        <div class="form-group mb-3">
                            <label for="excel-separados-file" class="form-label">Selecione a planilha (.xlsx):</label>
                            <div class="custom-file-upload mt-2">
                                <input type="file" id="excel-separados-file" accept=".xlsx, .xls" style="display: none;">
                                <label for="excel-separados-file" class="btn btn-outline-secondary w-100 mb-0" style="cursor: pointer; padding: 10px;">
                                    <i class="fas fa-upload mr-2"></i> Escolher Arquivo
                                </label>
                            </div>
                            <small id="nome-arquivo-excel" class="form-text text-center font-weight-bold mt-3" style="color: var(--accent-orange);"></small>
                        </div>
                        <button type="submit" class="btn-premium outline w-100" style="border-color: #28a745; color: #28a745;" id="btn-enviar-excel">
                            <i class="fas fa-cloud-upload-alt mr-2"></i> Subir Planilha
                        </button>
                    </form>
                    
                    <br>
                    <div id="area-pin-excel" class="mt-4 text-center p-3 rounded" style="background-color: rgba(40, 167, 69, 0.05); border: 1px solid rgba(40, 167, 69, 0.2);">
                        <p class="mb-2" style="color: var(--text-secondary); font-size: 0.9em;">A senha (PIN) de hoje para usar esta planilha é:</p>
                        <h2 class="text-success font-weight-bold display-4 mb-0" id="pin-display" style="letter-spacing: 10px;">{{senhaDoDia}}</h2>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

{{#section "scripts"}}
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="/public/scripts/toastSystem.js"></script>
<script src="/public/scripts/gondolaManager.js"></script>
{{/section}}