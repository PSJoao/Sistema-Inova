{{#section "head" }}
<link href="/public/styles/bipagemExpedicao.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
{{/section}}

<div class="bipagem-wrapper">
    <div class="bipagem-header">
        <h1>Conferência de Expedição</h1>
    </div>

    {{> messages}}

    <div class="bipagem-grid">
        <!-- ÁREA DO SCANNER -->
        <div class="bipagem-panel" id="area-bipagem"
            style="opacity: 0.3; pointer-events: none; transition: opacity 0.3s;">
            <div class="bipagem-panel-title"
                style="display: flex; justify-content: space-between; align-items: center;">
                <span><i class="fas fa-qrcode"></i> Leitura de Volumes</span>
            </div>

            <div class="palete-indicator" id="palete-indicator">
                <div class="palete-indicator-info">
                    <i class="fas fa-pallet" style="color: var(--accent-orange); margin-right: 8px;"></i>
                    <span id="palete-indicator-label" style="color: var(--text-secondary); font-size: 0.85rem;">Nenhum
                        palete selecionado</span>
                    <span id="palete-vol-count" class="palete-vol-badge" style="display: none;">0 vol</span>
                </div>
                <button id="btn-novo-palete-quick" class="btn-bip" title="Criar Novo Palete" disabled
                    style="padding: 0.3rem 0.7rem; font-size: 0.8rem;">
                    <i class="fas fa-plus" style="margin-right: 4px;"></i> Novo Palete
                </button>
            </div>

            <div class="scanner-area">
                <input type="text" id="input-bipagem" class="scanner-input" placeholder="BIPAR CÓDIGO AQUI"
                    autocomplete="off">
            </div>

            <div class="bip-status-grid">
                <div class="bip-status-box" id="box-nf-atual">
                    <h6>NF Atual Aberta</h6>
                    <div id="display-nf" class="nf-display-value text-muted"
                        style="color: var(--text-muted) !important;">Nenhuma</div>
                    <button id="btn-encerrar-nf" class="btn-bip-encerrar" style="display: none;">
                        <i class="fas fa-check-circle"></i> Gravar
                    </button>
                </div>

                <div class="bip-status-box">
                    <h6>Carregadores (Rateio)</h6>
                    <ul id="lista-carregadores-bipados" class="carregadores-list">
                        <li style="background: transparent; padding: 0;"><span class="text-muted"
                                style="font-size: 0.9rem;">Nenhum bipado.</span></li>
                    </ul>
                </div>
                <div style="grid-column: 1 / -1; display: flex; justify-content: center; margin-top: 5px;">
                    <label style="cursor: pointer; display: flex; align-items: center; gap: 10px; margin-bottom: 0;">
                        <span id="label-modo-carregador" style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); transition: color 0.3s;">Com Carregador</span>
                        <div style="position: relative; display: inline-block; width: 44px; height: 24px;">
                            <input type="checkbox" id="chk-sem-carregador" style="opacity: 0; width: 0; height: 0;" onchange="
                                const lbl = document.getElementById('label-modo-carregador');
                                if(this.checked) {
                                    lbl.innerText = 'Sem Carregador';
                                    lbl.style.color = 'var(--accent-orange)';
                                    this.nextElementSibling.style.backgroundColor = 'var(--accent-orange)';
                                    this.nextElementSibling.style.borderColor = 'var(--accent-orange)';
                                    this.nextElementSibling.nextElementSibling.style.transform = 'translateX(20px)';
                                    this.nextElementSibling.nextElementSibling.style.backgroundColor = '#1e1e2f';
                                } else {
                                    lbl.innerText = 'Com Carregador';
                                    lbl.style.color = 'var(--text-secondary)';
                                    this.nextElementSibling.style.backgroundColor = 'rgba(255,255,255,0.05)';
                                    this.nextElementSibling.style.borderColor = 'rgba(255,255,255,0.1)';
                                    this.nextElementSibling.nextElementSibling.style.transform = 'translateX(0)';
                                    this.nextElementSibling.nextElementSibling.style.backgroundColor = '#888';
                                }
                            ">
                            <span style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(255,255,255,0.05); transition: 0.3s; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1);"></span>
                            <span style="position: absolute; height: 14px; width: 14px; left: 4px; bottom: 4px; background-color: #888; transition: 0.3s; border-radius: 50%; pointer-events: none;"></span>
                        </div>
                    </label>
                </div>
            </div>
        </div>

        <div class="bipagem-panel">
            <div class="bipagem-panel-title">
                <i class="fas fa-truck"></i> Destino da Carga
            </div>

            <div class="bip-form-group">
                <label class="bip-label">1. Coleta (Caminhão)</label>
                <div class="bip-input-group">
                    <select id="select-coleta" class="bip-select">
                        <option value="">Carregando...</option>
                    </select>
                    <button id="btn-nova-coleta" class="btn-bip" title="Criar Nova Coleta"><i
                            class="fas fa-plus"></i></button>
                    <button id="btn-delete-coleta" class="btn-bip danger" title="Deletar Coleta"><i
                            class="fas fa-trash"></i></button>
                </div>
            </div>

            <div class="bip-form-group" style="margin-top: 1rem;">
                <label class="bip-label">2. Palete Atual</label>
                <div class="bip-input-group">
                    <select id="select-palete" class="bip-select" disabled>
                        <option value="">Selecione coleta primeiro</option>
                    </select>
                    <button id="btn-novo-palete" class="btn-bip" title="Criar Novo Palete" disabled><i
                            class="fas fa-plus"></i></button>
                    <button id="btn-delete-palete" class="btn-bip danger" title="Deletar Palete" disabled><i
                            class="fas fa-trash"></i></button>
                </div>
            </div>

            <div id="status-configuracao" class="alert-custom">
                <i class="fas fa-exclamation-triangle"></i> Defina a coleta e o palete para iniciar.
            </div>
        </div>
    </div>

    <!-- HIERARQUIA EM TEMPO REAL -->
    <div class="hierarchy-panel">
        <div class="hierarchy-header">
            <h2>Resumo de Expedição (Hoje)</h2>
            <div style="display: flex; gap: 10px; align-items: center;">
                <button id="btn-imprimir-resumo" class="btn-premium orange"
                    style="padding: 0.4rem 0.8rem; font-size: 0.85rem; border-radius: 6px;">
                    <i class="fas fa-file-pdf"></i> Imprimir Resumo
                </button>
                <div class="hierarchy-badge" id="badge-total-nfs">0 NFs expedidas</div>
            </div>
        </div>
        <div class="hierarchy-body" id="hierarquia-container">
            <div style="text-align: center; color: var(--text-muted); padding: 2rem;">
                <i class="fas fa-spinner fa-spin"></i> Carregando hierarquia real...
            </div>
        </div>
    </div>
</div>

<audio id="audio-success" src="/public/sounds/notification.mp3"></audio>
<audio id="audio-error" src="/public/sounds/error.mp3"></audio>

{{#section "scripts"}}
<script src="/public/scripts/toastSystem.js"></script>
<script src="/public/scripts/bipagemExpedicaoManager.js"></script>
{{/section}}